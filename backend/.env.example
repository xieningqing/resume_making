# ══════════════════════════════════════════════════
#  数据库配置
# ══════════════════════════════════════════════════

# 数据库连接字符串
# 格式: mysql+aiomysql://用户名:密码@主机地址:端口/数据库名?charset=utf8mb4&auth_plugin=mysql_clear_password
# - 使用 aiomysql 驱动（异步）
# - auth_plugin 参数用于兼容 MySQL 8.0+ 的密码认证方式
DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/resume_maker?charset=utf8mb4&auth_plugin=mysql_clear_password

# ══════════════════════════════════════════════════
#  安全与鉴权
# ══════════════════════════════════════════════════

# JWT 签名密钥，务必替换为随机字符串（越长越安全）
# 可用命令生成: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-string

# JWT 签名算法，一般不需要修改
ALGORITHM=HS256

# Access Token 有效期（单位：小时），过期后需重新登录
ACCESS_TOKEN_EXPIRE_HOURS=24

# 邮箱验证码有效期（单位：分钟），超时后验证码失效，需重新获取
CODE_EXPIRE_MINUTES=5

# ══════════════════════════════════════════════════
#  跨域配置
# ══════════════════════════════════════════════════

# 允许的前端来源地址，多个用英文逗号分隔
# 开发环境通常为 localhost:5173（Vite 默认端口）
# 生产环境需改为实际部署域名，如 https://your-domain.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ══════════════════════════════════════════════════
#  邮件 SMTP 配置（用于发送验证码）
# ══════════════════════════════════════════════════

# QQ 邮箱配置步骤:
# 1. 登录 QQ 邮箱 -> 设置 -> 账户 -> 开启 SMTP 服务
# 2. 生成授权码（不是 QQ 密码），填入 SMTP_PASSWORD
# 其他邮箱请查阅对应 SMTP 服务器地址和端口

# SMTP 服务器地址
SMTP_HOST=smtp.qq.com

# SMTP 端口: 465(SSL) 或 587(TLS)
SMTP_PORT=465

# 发件人邮箱地址
SMTP_USER=your-qq-email@qq.com

# 邮箱授权码（不是登录密码）
SMTP_PASSWORD=your-qq-smtp-auth-code

# 邮件中显示的发件人名称
SMTP_FROM_NAME=简历制作平台

# ══════════════════════════════════════════════════
#  阿里云 OSS 对象存储（用于简历头像上传）
# ══════════════════════════════════════════════════

# 配置步骤:
# 1. 登录阿里云控制台 -> 对象存储 OSS -> 创建 Bucket
# 2. Bucket 读写权限设置为「公共读」
# 3. 在 RAM 访问控制中创建用户，授予 OSS 读写权限
# 4. 获取 AccessKey ID 和 Secret
# AccessKey 管理地址: https://ram.console.aliyun.com/manage/ak

# AccessKey ID
OSS_ACCESS_KEY_ID=

# AccessKey Secret
OSS_ACCESS_KEY_SECRET=

# Bucket 名称，如 resume-maker
OSS_BUCKET_NAME=

# OSS Endpoint（不含 https:// 前缀）
# 各地域 Endpoint 参考: https://help.aliyun.com/document_detail/31837.html
# 示例: oss-cn-hangzhou.aliyuncs.com
OSS_ENDPOINT=

# OSS 公网访问域名，用于拼接图片 URL
# 格式: https://{Bucket名称}.{Endpoint}
# 示例: https://resume-maker.oss-cn-hangzhou.aliyuncs.com
OSS_PUBLIC_URL=
